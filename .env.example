DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diploma?schema=public"
NEXT_PUBLIC_SOLANA_RPC="https://api.devnet.solana.com"

# Опционально: локальные текстуры глобуса (см. public/textures/earth/README.md)
# Качество сферы: `NEXT_PUBLIC_EARTH_QUALITY=high` (256 сегм., игнорирует EARTH_SPHERE_SEGMENTS) или `low` (96).
# Если EARTH_QUALITY не задан — можно задать только NEXT_PUBLIC_EARTH_SPHERE_SEGMENTS (32–256).
# NEXT_PUBLIC_EARTH_MAX_PIXEL_RATIO="3" — верхний предел DPR для WebGL (по умолчанию при high: 3, иначе 2.5).
# NEXT_PUBLIC_EARTH_TEXTURE_BASE="/textures/earth/"
# NEXT_PUBLIC_EARTH_QUALITY="high"
# NEXT_PUBLIC_EARTH_QUALITY="low"
# NEXT_PUBLIC_EARTH_SPHERE_SEGMENTS="192"
# NEXT_PUBLIC_EARTH_MATERIAL="phong"
# NEXT_PUBLIC_EARTH_MAP_FILE="earth_atmos_2048.jpg"

# Опционально: URL GeoJSON подводных кабелей для scripts/sync-submarine-cables.mjs
# SUBMARINE_CABLE_GEO_URL="https://raw.githubusercontent.com/stevesong/open_undersea_cable_map/main/cable/cable-geo.json"

# Stage 12 — shared rate limit backend (optional)
# If set to `redis` and `REDIS_URL` is provided, backend rate limiting will use Redis.
RATE_LIMIT_BACKEND="inmemory" # or: "redis"
REDIS_URL="redis://localhost:6379/0"

# Stage 12 — governance / moderation allowlist (Phantom `/api/moderation/*` fallback).
# @deprecated — предпочтительно назначать модераторов через `/admin` → ModeratorGrant (`npm run migrate:moderator-env`).
# Comma-separated base58 pubkeys of moderators/operators.
MODERATOR_PUBKEYS=""

# Admin panel (/admin, /admin/login) — staff httpOnly session cookie `diploma_staff_session`
# Secret for signed login nonces (GET /api/admin/auth/nonce). Min length 16 ASCII.
# STAFF_SESSION_SECRET="change-me-min-16-chars"
#
# Phantom wallet admin login: pubkey должен совпадать с подключённым кошельком на /admin/login.
# ADMIN_WALLET_PUBKEY=""

# Локальный smoke `npm run test:admin-smoke`: base58 секретного ключа (32-byte seed или 64-byte secret),
# pubkey которого совпадает с ADMIN_WALLET_PUBKEY. Только для dev/CI, не для продакшена.
# ADMIN_SMOKE_WALLET_SECRET=""

# Cron: синхронизация RSS новостей → NewsCache (POST /api/cron/news-sync, см. docs/operations.md)
# Только ASCII (латиница/цифры/символы), без кириллицы — иначе ошибка в HTTP-заголовке.
# CRON_SECRET="min-8-chars-ascii-random"


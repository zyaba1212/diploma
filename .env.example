DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diploma?schema=public"
NEXT_PUBLIC_SOLANA_RPC="https://api.devnet.solana.com"

# Опционально: локальные текстуры глобуса (см. public/textures/earth/README.md)
# NEXT_PUBLIC_EARTH_TEXTURE_BASE="/textures/earth/"
# NEXT_PUBLIC_EARTH_QUALITY="high"
# NEXT_PUBLIC_EARTH_SPHERE_SEGMENTS="160"
# NEXT_PUBLIC_EARTH_MATERIAL="standard"
# NEXT_PUBLIC_EARTH_MAP_FILE="earth_atmos_2048.jpg"

# Опционально: URL GeoJSON подводных кабелей для scripts/sync-submarine-cables.mjs
# SUBMARINE_CABLE_GEO_URL="https://raw.githubusercontent.com/stevesong/open_undersea_cable_map/main/cable/cable-geo.json"

# Stage 12 — shared rate limit backend (optional)
# If set to `redis` and `REDIS_URL` is provided, backend rate limiting will use Redis.
RATE_LIMIT_BACKEND="inmemory" # or: "redis"
REDIS_URL="redis://localhost:6379/0"

# Stage 12 — governance / moderation allowlist (planned for /api/moderation/*)
# Comma-separated base58 pubkeys of moderators/operators.
MODERATOR_PUBKEYS=""

# Cron: синхронизация RSS новостей → NewsCache (POST /api/cron/news-sync, см. docs/operations.md)
# Только ASCII (латиница/цифры/символы), без кириллицы — иначе ошибка в HTTP-заголовке.
# CRON_SECRET="min-8-chars-ascii-random"

